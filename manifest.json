{
  "manifest_version": 3,
  "name": "Reframe MVP",
  "description": "Toggle a generic black-and-white overlay that remaps interactions back to the original page.",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/constants.js",
        "src/utils.js",
        "src/locator.js",
        "src/state.js",
        "src/capture.js",
        "src/bridge.js",
        "src/render.js",
        "src/runtime.js",
        "src/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
